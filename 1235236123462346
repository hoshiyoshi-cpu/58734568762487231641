    WBList.BackgroundTransparency = 1
    WBList.ScrollBarThickness = 3
    WBList.ScrollBarImageColor3 = THEME.Accent
    WBList.CanvasSize = UDim2.new(0,0,0,0)

    local WBLayout = Instance.new("UIListLayout", WBList)
    WBLayout.Padding = UDim.new(0, 2)
    WBLayout.SortOrder = Enum.SortOrder.LayoutOrder

    local function SearchWords()
        for _, c in ipairs(WBList:GetChildren()) do
            if c:IsA("GuiObject") and c.Name ~= "UIListLayout" then c:Destroy() end
        end

        local priorityVal = WBEndBox.Text
        local depriorityVal = WBDepriorityBox.Text
        local lVal = tonumber(WBLengthBox.Text)
        
        if priorityVal == "ends with (priority - highest to lowest)" then priorityVal = "" end
        if depriorityVal == "ends with (depriority - goes before fallback)" then depriorityVal = "" end
        
        priorityVal = priorityVal:lower():gsub("[%s%c]+", "")
        depriorityVal = depriorityVal:lower():gsub("[%s%c]+", "")

        local prioritySuffixes = {}
        for part in priorityVal:gmatch("[^,]+") do
            local clean = part:gsub("[%s%c]+", "")
            if #clean > 0 then 
                table.insert(prioritySuffixes, clean)
            end
        end
        
        local deprioritySuffixes = {}
        for part in depriorityVal:gmatch("[^,]+") do
            local clean = part:gsub("[%s%c]+", "")
            if #clean > 0 then 
                table.insert(deprioritySuffixes, clean)
            end
        end
        
        Config.SuffixModes = prioritySuffixes
        Config.SuffixMode = priorityVal
        Config.DepriorityModes = deprioritySuffixes
        Config.DepriorityMode = depriorityVal
        Config.LengthMode = lVal or 0
        SaveConfig()
        
        local priorityMap = {}
        for idx, s in ipairs(prioritySuffixes) do
            priorityMap[s] = idx
        end
        
        local depriorityMap = {}
        for _, s in ipairs(deprioritySuffixes) do
            depriorityMap[s] = true
        end
        
        local function getWordPriority(w)
            local bestPriority = 999
            for _, s in ipairs(prioritySuffixes) do
                if #w >= #s and w:sub(-#s) == s then
                    local p = priorityMap[s] or 999
                    if p < bestPriority then
                        bestPriority = p
                    end
                end
            end
            return bestPriority
        end
        
        local function isDepriorityWord(w)
            for _, s in ipairs(deprioritySuffixes) do
                if #w >= #s and w:sub(-#s) == s then
                    return true
                end
            end
            return false
        end
        
        local function matchesLength(w)
            return (lVal == nil or lVal == 0) or (#w == lVal)
        end
        
        local allWords = {}
        local seen = {}
        
        for _, w in ipairs(PrimaryWords) do
            if not Blacklist[w] and not UsedWords[w] and matchesLength(w) then
                if not seen[w] then
                    seen[w] = true
                    table.insert(allWords, w)
                end
            end
        end
        
        for _, w in ipairs(FallbackWords) do
            if not Blacklist[w] and not UsedWords[w] and matchesLength(w) then
                if not seen[w] then
                    seen[w] = true
                    table.insert(allWords, w)
                end
            end
        end
        
        if #prioritySuffixes == 0 and #deprioritySuffixes == 0 then
            table.sort(allWords)
            
            local displayLimit = math.min(200, #allWords)
            for i = 1, displayLimit do
                local w = allWords[i]
                local row = Instance.new("TextButton", WBList)
                row.Size = UDim2.new(1, -6, 0, 22)
                row.BackgroundColor3 = (i % 2 == 0) and Color3.fromRGB(25,25,30) or Color3.fromRGB(30,30,35)
                row.Text = ""
                row.AutoButtonColor = false
                Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)
                row.MouseButton1Click:Connect(function()
                    Tween(row, {BackgroundColor3 = THEME.Accent}, 0.2)
                    task.delay(0.2, function()
                        Tween(row, {BackgroundColor3 = (i % 2 == 0) and Color3.fromRGB(25,25,30) or Color3.fromRGB(30,30,35)}, 0.2)
                    end)
                    if SearchBox then
                        SearchBox.Text = w
                    end
                end)
                local lbl = Instance.new("TextLabel", row)
                local isPrimary = false
                for _, pw in ipairs(PrimaryWords) do
                    if pw == w then 
                        isPrimary = true 
                        break 
                    end
                end
                lbl.Text = w
                lbl.Font = Enum.Font.Gotham
                lbl.TextSize = 12
                lbl.TextColor3 = isPrimary and THEME.Success or THEME.Text
                lbl.Size = UDim2.new(1, -10, 1, 0)
                lbl.Position = UDim2.new(0, 5, 0, 0)
                lbl.BackgroundTransparency = 1
                lbl.TextXAlignment = Enum.TextXAlignment.Left
            end
            
            WBList.CanvasSize = UDim2.new(0,0,0, WBLayout.AbsoluteContentSize.Y)
            lastDetected = "---"
            forceUpdateList = true
            if UpdateList then UpdateList(lastDetected, lastRequiredLetter) end
            return
        end
        
        local priorityResults = {}
        local depriorityWords = {}
        local normalWords = {}
        local MAX_RESULTS = 200
        
        for _, w in ipairs(allWords) do
            local priority = getWordPriority(w)
            if priority < 999 then
                if not priorityResults[priority] then
                    priorityResults[priority] = {}
                end
                table.insert(priorityResults[priority], w)
            elseif isDepriorityWord(w) then
                table.insert(depriorityWords, w)
            else
                table.insert(normalWords, w)
            end
        end
        
        local sortedResults = {}
        local priorities = {}
        for p, _ in pairs(priorityResults) do
            table.insert(priorities, p)
        end
        table.sort(priorities)
        
        for _, p in ipairs(priorities) do
            local group = priorityResults[p]
            table.sort(group, function(a, b) 
                if #a ~= #b then return #a < #b end
                return a < b
            end)
            for _, word in ipairs(group) do
                table.insert(sortedResults, word)
                if #sortedResults >= MAX_RESULTS then break end
            end
            if #sortedResults >= MAX_RESULTS then break end
        end
        
        table.sort(normalWords, function(a, b)
            if #a ~= #b then return #a < #b end
            return a < b
        end)
        for _, word in ipairs(normalWords) do
            if #sortedResults >= MAX_RESULTS then break end
            table.insert(sortedResults, word)
        end
        
        table.sort(depriorityWords, function(a, b)
            if #a ~= #b then return #a < #b end
            return a < b
        end)
        for _, word in ipairs(depriorityWords) do
            if #sortedResults >= MAX_RESULTS then break end
            table.insert(sortedResults, word)
        end
        
        local displayLimit = math.min(200, #sortedResults)
        if displayLimit == 0 then
            local msg = "No words found"
            if #prioritySuffixes > 0 then msg = msg .. " ending with: " .. priorityVal end
            if #deprioritySuffixes > 0 then msg = msg .. " (depriority: " .. depriorityVal .. ")" end
            ShowToast(msg, "warning")
        end
        
        for i = 1, displayLimit do
            local w = sortedResults[i]
            local row = Instance.new("TextButton", WBList)
            row.Size = UDim2.new(1, -6, 0, 22)
            row.BackgroundColor3 = (i % 2 == 0) and Color3.fromRGB(25,25,30) or Color3.fromRGB(30,30,35)
            row.Text = ""
            row.AutoButtonColor = false
            Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)
            row.MouseButton1Click:Connect(function()
                Tween(row, {BackgroundColor3 = THEME.Accent}, 0.2)
                task.delay(0.2, function()
                    Tween(row, {BackgroundColor3 = (i % 2 == 0) and Color3.fromRGB(25,25,30) or Color3.fromRGB(30,30,35)}, 0.2)
                end)
                if SearchBox then
                    SearchBox.Text = w
                end
            end)
            local lbl = Instance.new("TextLabel", row)
            local isPrimary = false
            for _, pw in ipairs(PrimaryWords) do
                if pw == w then 
                    isPrimary = true 
                    break 
                end
            end
            
            lbl.Text = w
            lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 12
            lbl.Size = UDim2.new(1, -10, 1, 0)
            lbl.Position = UDim2.new(0, 5, 0, 0)
            lbl.BackgroundTransparency = 1
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            
            local matchedPriority = getWordPriority(w)
            if matchedPriority < 999 then
                if matchedPriority == 1 then
                    lbl.TextColor3 = THEME.Success
                elseif matchedPriority == 2 then
                    lbl.TextColor3 = THEME.Warning
                elseif matchedPriority == 3 then
                    lbl.TextColor3 = THEME.Accent
                else
                    lbl.TextColor3 = Color3.fromRGB(200, 150, 255)
                end
            elseif isDepriorityWord(w) then
                lbl.TextColor3 = Color3.fromRGB(255, 150, 100)
            else
                lbl.TextColor3 = isPrimary and THEME.Success or THEME.Text
            end
        end

        WBList.CanvasSize = UDim2.new(0,0,0, WBLayout.AbsoluteContentSize.Y)
        lastDetected = "---"
        forceUpdateList = true
        
        if #prioritySuffixes > 0 or #deprioritySuffixes > 0 then
            local msg = ""
            if #prioritySuffixes > 0 then
                msg = "Priority: "
                for i, s in ipairs(prioritySuffixes) do
                    if i > 1 then msg = msg .. ", " end
                    msg = msg .. s .. " (#" .. i .. ")"
                end
            end
            if #deprioritySuffixes > 0 then
                if msg ~= "" then msg = msg .. " | " end
                msg = msg .. "Depriority: " .. table.concat(deprioritySuffixes, ", ")
            end
            msg = msg .. " | Found " .. #sortedResults .. " words"
            ShowToast(msg, "success")
        end
        
        if UpdateList then 
            UpdateList(lastDetected, lastRequiredLetter)
        end
    end

    WBSearchBtn.MouseButton1Click:Connect(SearchWords)
    WBClearBtn.MouseButton1Click:Connect(function()
        WBEndBox.Text = ""
        WBDepriorityBox.Text = ""
        WBLengthBox.Text = "Len..."
        SearchWords()
    end)
    WBEndBox.FocusLost:Connect(function(enter) if enter then SearchWords() end end)
    WBDepriorityBox.FocusLost:Connect(function(enter) if enter then SearchWords() end end)
    WBLengthBox.FocusLost:Connect(function(enter) if enter then SearchWords() end end)
    
    WordBrowserBtn.MouseButton1Click:Connect(function()
        WordBrowserFrame.Visible = not WordBrowserFrame.Visible
        WordBrowserFrame.Parent = nil
        WordBrowserFrame.Parent = ScreenGui
        if WordBrowserFrame.Visible then
            WBEndBox.Text = Config.SuffixMode or ""
            WBDepriorityBox.Text = Config.DepriorityMode or ""
            WBLengthBox.Text = (Config.LengthMode and Config.LengthMode > 0) and tostring(Config.LengthMode) or "Len..."
        end
    end)
end

