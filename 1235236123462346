-- =============================================
-- MAIN UPDATE LIST FUNCTION (DEPRIORITY OVERRIDES ALL RANDOMIZERS)
-- =============================================

local lastRequiredLetter = ""

UpdateList = function(detectedText, requiredLetter)

    local ProWordsLookup = ProWordsLookup
    local GiveWordsLookup = GiveWordsLookup

    local hash = (detectedText or "") .. "|" .. (requiredLetter or "") .. "|" .. (SearchBox.Text or "") .. "|" .. suffixMode .. "|" .. depriorityMode .. "|" .. tostring(lengthMode) .. "|" .. sortMode
    if hash == lastUpdateHash and not forceUpdateList then return end
    lastUpdateHash = hash

    local searchPrefix = detectedText
    local manualSearch = false

    if SearchBox and SearchBox.Text ~= "" then
        searchPrefix = SearchBox.Text:lower():gsub("[%s%c]+", "")
        manualSearch = true
        if requiredLetter and searchPrefix:sub(1,1) ~= requiredLetter:sub(1,1):lower() then
            requiredLetter = nil
        end
    end

    if not manualSearch and requiredLetter and #requiredLetter > 0 then
        local reqLen = GetMatchLength(requiredLetter, searchPrefix)
        if reqLen == #searchPrefix and #requiredLetter > #searchPrefix then
            searchPrefix = requiredLetter
        end
    end

    local firstChar = searchPrefix:sub(1,1)
    if firstChar == "#" then firstChar = nil end
    if (not firstChar or firstChar == "") and requiredLetter then
        firstChar = requiredLetter:sub(1,1):lower()
    end

    local prefixLen = #searchPrefix
    local prioritySuffixes = Config.SuffixModes or {}
    local deprioritySuffixes = Config.DepriorityModes or {}
    
    -- Function to check if a word ends with ANY depriority suffix
    local function hasDeprioritySuffix(w)
        for _, s in ipairs(deprioritySuffixes) do
            if #w >= #s and w:sub(-#s) == s then
                return true
            end
        end
        return false
    end
    
    -- Function to check if a word has priority suffix
    local function hasPrioritySuffix(w)
        for _, s in ipairs(prioritySuffixes) do
            if #w >= #s and w:sub(-#s) == s then
                return true
            end
        end
        return false
    end
    
    -- COLLECT ALL prefix-matching words (NO FILTERING)
    local allMatchingWords = {}
    local bucket = firstChar and Buckets[firstChar] or AllWords
    
    if bucket then
        for _, w in ipairs(bucket) do
            if prefixLen == 0 or w:sub(1, prefixLen) == searchPrefix then
                if lengthMode == 0 or #w == lengthMode then
                    if not Blacklist[w] and not UsedWords[w] then
                        table.insert(allMatchingWords, w)
                    end
                end
            end
        end
    end
    
    -- Find shortest word (ignores all suffix rules)
    local shortestWord = nil
    local shortestLen = math.huge
    for _, w in ipairs(allMatchingWords) do
        if #w < shortestLen and w ~= searchPrefix then
            shortestLen = #w
            shortestWord = w
        end
    end
    if not shortestWord then
        for _, w in ipairs(allMatchingWords) do
            if #w < shortestLen then
                shortestLen = #w
                shortestWord = w
            end
        end
    end
    
    -- Track used words
    local usedInOrder = {}
    if shortestWord then usedInOrder[shortestWord] = true end
    
    -- Priority suffix words (in order of suffixes)
    local prioritySuffixWords = {}
    for _, suffix in ipairs(prioritySuffixes) do
        local bestForSuffix = nil
        local shortestForSuffix = math.huge
        
        for _, w in ipairs(allMatchingWords) do
            if not usedInOrder[w] then
                if #w >= #suffix and w:sub(-#suffix) == suffix then
                    if #w < shortestForSuffix then
                        shortestForSuffix = #w
                        bestForSuffix = w
                    end
                end
            end
        end
        
        if bestForSuffix then
            table.insert(prioritySuffixWords, bestForSuffix)
            usedInOrder[bestForSuffix] = true
        end
    end
    
    -- Custom priority words
    local customPriorityWords = {}
    if searchPrefix and searchPrefix ~= "" and PriorityWords[searchPrefix] then
        local priorityList = GetPriorityWordsForPrefix(searchPrefix)
        for _, w in ipairs(priorityList) do
            local wordExists = false
            for _, existing in ipairs(allMatchingWords) do
                if existing == w then
                    wordExists = true
                    break
                end
            end
            if wordExists and not usedInOrder[w] and w ~= searchPrefix then
                table.insert(customPriorityWords, w)
                usedInOrder[w] = true
            end
        end
        table.sort(customPriorityWords, function(a, b) return #a < #b end)
    end
    
    -- Separate remaining words into GIVE, DEPRIORITY, and FALLBACK
    local giveWords = {}
    local depriorityWords = {}
    local fallbackWords = {}

    local function IsGiveWord(word)
        if sortMode == "Pro" then
            -- PRIORITY 1: progives.txt words
            if ProWordsLookup[word] then
                return true
            end
            -- PRIORITY 2: gives.txt words
            return GiveWordsLookup[word] == true
        else
            return GiveWordsLookup[word] == true
        end
    end

    for _, w in ipairs(allMatchingWords) do
        if not usedInOrder[w] then
            if sortMode == "Pro" then
                -- Pro mode: ignore depriority suffixes completely
                if IsGiveWord(w) then
                    table.insert(giveWords, w)
                else
                    table.insert(fallbackWords, w)
                end
            else
                -- Other modes: respect depriority suffixes
                if hasDeprioritySuffix(w) then
                    table.insert(depriorityWords, w)
                elseif IsGiveWord(w) then
                    table.insert(giveWords, w)
                else
                    table.insert(fallbackWords, w)
                end
            end
        end
    end
        
    -- ========== SORT EACH CATEGORY ACCORDING TO MODE ==========
    
    -- Sort GIVE words based on mode (but depriority words will go to bottom AFTER this)
    local sortedGive = {}

    if sortMode == "Strategic" then
        -- Strategic: 4-7 letters first, then others, both randomized
        local shortGives = {}
        local longGives = {}
        
        for _, w in ipairs(giveWords) do
            local len = #w
            if len >= 4 and len <= 7 then
                table.insert(shortGives, w)
            else
                table.insert(longGives, w)
            end
        end
        
        -- Randomize both groups
        for i = #shortGives, 2, -1 do
            local j = math.random(i)
            shortGives[i], shortGives[j] = shortGives[j], shortGives[i]
        end
        for i = #longGives, 2, -1 do
            local j = math.random(i)
            longGives[i], longGives[j] = longGives[j], longGives[i]
        end
        
        for _, w in ipairs(shortGives) do table.insert(sortedGive, w) end
        for _, w in ipairs(longGives) do table.insert(sortedGive, w) end
        
    elseif sortMode == "Smart" then
        -- Smart: 6-9 letters first, then <=5, then >9, all randomized
        local mediumGive = {}
        local shortGive = {}
        local longGive = {}
        
        for _, w in ipairs(giveWords) do
            local len = #w
            if len >= 6 and len <= 9 then
                table.insert(mediumGive, w)
            elseif len <= 5 then
                table.insert(shortGive, w)
            else
                table.insert(longGive, w)
            end
        end
        
        for i = #mediumGive, 2, -1 do local j = math.random(i) mediumGive[i], mediumGive[j] = mediumGive[j], mediumGive[i] end
        for i = #shortGive, 2, -1 do local j = math.random(i) shortGive[i], shortGive[j] = shortGive[j], shortGive[i] end
        for i = #longGive, 2, -1 do local j = math.random(i) longGive[i], longGive[j] = longGive[j], longGive[i] end
        
        for _, w in ipairs(mediumGive) do table.insert(sortedGive, w) end
        for _, w in ipairs(shortGive) do table.insert(sortedGive, w) end
        for _, w in ipairs(longGive) do table.insert(sortedGive, w) end
        
    elseif sortMode == "Random" then
        -- Pure random
        for i = #giveWords, 2, -1 do
            local j = math.random(i)
            giveWords[i], giveWords[j] = giveWords[j], giveWords[i]
        end
        sortedGive = giveWords
        
    elseif sortMode == "Pro" then
        -- PRO MODE: Separate PRO words and regular GIVE words
        local proOnly = {}
        local regularGive = {}
        
        for _, w in ipairs(giveWords) do
            if ProWordsLookup[w] then
                table.insert(proOnly, w)
            else
                table.insert(regularGive, w)
            end
        end
        
        -- Sort PRO words by length (shortest first)
        table.sort(proOnly, function(a, b) return #a < #b end)
        -- Sort regular GIVE words by length (shortest first)
        table.sort(regularGive, function(a, b) return #a < #b end)
        
        -- Combine: PRO words first, then regular GIVE words
        sortedGive = {}
        for _, w in ipairs(proOnly) do
            table.insert(sortedGive, w)
        end
        for _, w in ipairs(regularGive) do
            table.insert(sortedGive, w)
        end
        
    else  -- "Shortest" mode (default)
        -- Sort by length (shortest first)
        table.sort(giveWords, function(a, b) return #a < #b end)
        sortedGive = giveWords
    end
    
    -- Sort DEPRIORITY words (shortest first, then randomize same length)
    local sortedDepriority = {}
    -- Group by length
    local deprioLengthGroups = {}
    for _, w in ipairs(depriorityWords) do
        local len = #w
        if not deprioLengthGroups[len] then deprioLengthGroups[len] = {} end
        table.insert(deprioLengthGroups[len], w)
    end
    local deprioLengths = {}
    for len, _ in pairs(deprioLengthGroups) do
        table.insert(deprioLengths, len)
    end
    table.sort(deprioLengths)
    for _, len in ipairs(deprioLengths) do
        local group = deprioLengthGroups[len]
        -- Randomize within same length
        for i = #group, 2, -1 do
            local j = math.random(i)
            group[i], group[j] = group[j], group[i]
        end
        for _, w in ipairs(group) do
            table.insert(sortedDepriority, w)
        end
    end
    
    -- Sort FALLBACK words based on mode
    local sortedFallback = {}
    
    if sortMode == "Strategic" then
        local fbLengthGroups = {}
        for _, w in ipairs(fallbackWords) do
            local len = #w
            if not fbLengthGroups[len] then fbLengthGroups[len] = {} end
            table.insert(fbLengthGroups[len], w)
        end
        local fbLengths = {}
        for len, _ in pairs(fbLengthGroups) do
            table.insert(fbLengths, len)
        end
        table.sort(fbLengths)
        for _, len in ipairs(fbLengths) do
            local group = fbLengthGroups[len]
            for i = #group, 2, -1 do
                local j = math.random(i)
                group[i], group[j] = group[j], group[i]
            end
            for _, w in ipairs(group) do
                table.insert(sortedFallback, w)
            end
        end
        
    elseif sortMode == "Random" then
        for i = #fallbackWords, 2, -1 do
            local j = math.random(i)
            fallbackWords[i], fallbackWords[j] = fallbackWords[j], fallbackWords[i]
        end
        sortedFallback = fallbackWords
    elseif sortMode == "Smart" then
        for i = #fallbackWords, 2, -1 do
            local j = math.random(i)
            fallbackWords[i], fallbackWords[j] = fallbackWords[j], fallbackWords[i]
        end
        sortedFallback = fallbackWords
    else  -- "Shortest" or "Pro"
        table.sort(fallbackWords, function(a,b) return #a < #b end)
        sortedFallback = fallbackWords
    end
    
    -- ========== BUILD FINAL ORDER (DEPRIORITY ALWAYS GOES AFTER GIVE, BEFORE FALLBACK) ==========
    local matches = {}
    
    -- #1: Shortest word overall
    if shortestWord then table.insert(matches, shortestWord) end
    
    -- #2: Priority suffix words (in order of input)
    for _, w in ipairs(prioritySuffixWords) do
        local duplicate = false
        for _, existing in ipairs(matches) do
            if existing == w then duplicate = true; break end
        end
        if not duplicate then
            table.insert(matches, w)
        end
    end
    
    -- #3: Custom priority words
    for _, w in ipairs(customPriorityWords) do
        if #matches >= 40 then break end
        local duplicate = false
        for _, existing in ipairs(matches) do
            if existing == w then duplicate = true; break end
        end
        if not duplicate then
            table.insert(matches, w)
        end
    end
    
    -- #4: Give words (sorted according to mode)
    for _, w in ipairs(sortedGive) do
        if #matches >= 40 then break end
        table.insert(matches, w)
    end

    -- For Pro mode: depriority words go AFTER fallback (lowest priority)
    if sortMode == "Pro" then
        -- #5: Fallback words first (depriority is lowest)
        for _, w in ipairs(sortedFallback) do
            if #matches >= 40 then break end
            table.insert(matches, w)
        end
        -- #6: Depriority words (absolute lowest)
        for _, w in ipairs(sortedDepriority) do
            if #matches >= 40 then break end
            table.insert(matches, w)
        end
    else
        -- Other modes: depriority before fallback
        for _, w in ipairs(sortedDepriority) do
            if #matches >= 40 then break end
            table.insert(matches, w)
        end
        for _, w in ipairs(sortedFallback) do
            if #matches >= 40 then break end
            table.insert(matches, w)
        end
    end
    
    -- Display results (limit to 15 visible buttons)
    local displayList = {}
    for i = 1, math.min(15, #matches) do
        table.insert(displayList, matches[i])
    end
    
    -- Update status
    if #matches > 0 then
        currentBestMatch = matches[1]
        local modeText = (sortMode == "Pro") and "PRO" or ""
        local depriorityCount = #sortedDepriority
        local depriorityText = (depriorityCount > 0) and " | " .. depriorityCount .. " depriority" or ""
        StatusText.Text = "Found " .. #matches .. " words starting with '" .. searchPrefix .. "'" .. modeText .. depriorityText
        StatusText.TextColor3 = THEME.Success
        Tween(StatusDot, {BackgroundColor3 = THEME.Success})
    end
    
    -- Update buttons
    local giveWordsLookupLocal = GiveWordsLookup
    
    for i = 1, math.max(#displayList, #ButtonCache) do
        local w = displayList[i]
        local btn = ButtonCache[i]

        if w then
            local lbl
            if not btn then
                btn = Instance.new("TextButton")
                btn.Size = UDim2.new(1, -6, 0, 30)
                btn.BackgroundColor3 = THEME.ItemBG
                btn.Text = ""
                btn.AutoButtonColor = false
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

                lbl = Instance.new("TextLabel", btn)
                lbl.Name = "Label"
                lbl.Size = UDim2.new(1, -20, 1, 0)
                lbl.Position = UDim2.new(0, 10, 0, 0)
                lbl.BackgroundTransparency = 1
                lbl.Font = Enum.Font.GothamMedium
                lbl.TextSize = 14
                lbl.TextXAlignment = Enum.TextXAlignment.Left
                lbl.RichText = true

                -- Check if this is a PRO word (only in Pro mode)
                local isProWord = false
                if sortMode == "Pro" and ProWordsLookup and ProWordsLookup[w] then
                    isProWord = true
                end

                -- Add indicator for give words (either PRO or regular)
                if giveWordsLookupLocal and giveWordsLookupLocal[w] then
                    local giveIndicator = Instance.new("TextLabel", btn)
                    giveIndicator.Name = "GiveIndicator"
                    giveIndicator.Size = UDim2.new(0, 30, 1, 0)
                    giveIndicator.Position = UDim2.new(1, -35, 0, 0)
                    giveIndicator.BackgroundTransparency = 1
                    -- Show star for PRO words, gift for regular gives words
                    giveIndicator.Text = isProWord and "⭐" or "🎁"
                    giveIndicator.Font = Enum.Font.GothamBold
                    giveIndicator.TextSize = 12
                    -- Gold color for PRO words, green for regular gives
                    giveIndicator.TextColor3 = isProWord and Color3.fromRGB(255, 215, 0) or THEME.Success
                    giveIndicator.TextXAlignment = Enum.TextXAlignment.Right
                    lbl.Size = UDim2.new(1, -45, 1, 0)
                end

                btn.MouseEnter:Connect(function() Tween(btn, {BackgroundColor3 = Color3.fromRGB(45,45,55)}) end)
                btn.MouseLeave:Connect(function() Tween(btn, {BackgroundColor3 = THEME.ItemBG}) end)

                btn.MouseButton1Click:Connect(function()
                    local d = ButtonData[btn]
                    if d then
                        local l = btn:FindFirstChild("Label")
                        if l then l.TextColor3 = THEME.Success end
                        Tween(btn, {BackgroundColor3 = Color3.fromRGB(30,60,40)})
                        UsedWords[d.word] = tick()
                        forceUpdateList = true
                    end
                end)

                btn.Parent = ScrollList
                table.insert(ButtonCache, btn)
            else
                lbl = btn:FindFirstChild("Label")
                btn.Visible = true
                btn.Parent = ScrollList
                btn.BackgroundColor3 = THEME.ItemBG
                if lbl then lbl.TextColor3 = THEME.Text end
                
                local existingIndicator = btn:FindFirstChild("GiveIndicator")
                if giveWordsLookupLocal and giveWordsLookupLocal[w] then
                    if not existingIndicator then
                        local giveIndicator = Instance.new("TextLabel", btn)
                        giveIndicator.Name = "GiveIndicator"
                        giveIndicator.Size = UDim2.new(0, 30, 1, 0)
                        giveIndicator.Position = UDim2.new(1, -35, 0, 0)
                        giveIndicator.BackgroundTransparency = 1
                        giveIndicator.Text = "🎁"
                        giveIndicator.Font = Enum.Font.GothamBold
                        giveIndicator.TextSize = 12
                        giveIndicator.TextColor3 = THEME.Success
                        giveIndicator.TextXAlignment = Enum.TextXAlignment.Right
                        if lbl then lbl.Size = UDim2.new(1, -45, 1, 0) end
                    end
                elseif existingIndicator then
                    existingIndicator:Destroy()
                    if lbl then lbl.Size = UDim2.new(1, -20, 1, 0) end
                end
            end

            ButtonData[btn] = {word = w, detected = detectedText}

            local accentRGB = ColorToRGB(THEME.Accent)
            if i == 1 then
                accentRGB = "100,255,140"  -- Green for best match
            elseif i == 2 then
                accentRGB = "255,200,100"  -- Yellow for second
            elseif i == 3 then
                accentRGB = "100,200,255"  -- Blue for third
            end
            
            -- Color coding for depriority words (orange)
            if hasDeprioritySuffix(w) then
                accentRGB = "255,150,100"  -- Orange for depriority words
            elseif hasPrioritySuffix(w) then
                accentRGB = "90,230,206"   -- Cyan for priority suffix words
            end

            local textRGB = ColorToRGB(THEME.Text)
            local prefix = w:sub(1, #(detectedText or ""))
            local suffixPart = w:sub(#(detectedText or "") + 1)
            local displayText = "<font color=\"rgb(" .. accentRGB .. ")\">" .. prefix .. "</font>"
                .. "<font color=\"rgb(" .. textRGB .. ")\">" .. suffixPart .. "</font>"

            if lbl then lbl.Text = displayText end
        else
            if btn then
                btn.Visible = false
                ButtonData[btn] = nil
            end
        end
    end

    ScrollList.CanvasSize = UDim2.new(0,0,0, UIListLayout.AbsoluteContentSize.Y)
    forceUpdateList = false
end

