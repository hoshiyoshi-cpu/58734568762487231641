local BlacklistFile = "blacklist.txt"

local function LoadBlacklistFromFile()
    local loaded = {}
    if isfile and isfile(BlacklistFile) then
        local success, content = pcall(function() return readfile(BlacklistFile) end)
        if success and content then
            for line in content:gmatch("[^\r\n]+") do
                local word = line:gsub("[%s%c]+", ""):lower()
                if #word > 0 then
                    loaded[word] = true
                end
            end
        end
    end
    return loaded
end

local function SaveBlacklistToFile()
    if not writefile then return end
    local lines = {}
    for word, _ in pairs(Blacklist) do
        table.insert(lines, word)
    end
    table.sort(lines)
    local content = table.concat(lines, "\n")
    pcall(function() writefile(BlacklistFile, content) end)
end

