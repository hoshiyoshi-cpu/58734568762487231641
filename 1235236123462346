local function LoadPriorityWords()
    PriorityWords = {}
    PriorityPrefixList = {}
    
    if isfile and isfile(PriorityFile) then
        local success, content = pcall(function() return readfile(PriorityFile) end)
        if success and content then
            local currentPrefix = nil
            for line in content:gmatch("[^\r\n]+") do
                line = line:gsub("[%s%c]+", "")
                if line ~= "" then
                    if line:match("^%[(.+)%]$") then
                        currentPrefix = line:match("^%[(.+)%]$"):lower()
                        if not PriorityWords[currentPrefix] then
                            PriorityWords[currentPrefix] = {}
                            table.insert(PriorityPrefixList, currentPrefix)
                        end
                    elseif currentPrefix then
                        local word = line:lower()
                        if #word >= 2 then
                            PriorityWords[currentPrefix][word] = true
                        end
                    end
                end
            end
        end
    end
end

local function SavePriorityWords()
    if not writefile then return end
    
    local lines = {}
    for _, prefix in ipairs(PriorityPrefixList) do
        table.insert(lines, "[" .. prefix .. "]")
        local words = {}
        for word in pairs(PriorityWords[prefix]) do
            table.insert(words, word)
        end
        table.sort(words)
        for _, word in ipairs(words) do
            table.insert(lines, word)
        end
        table.insert(lines, "")
    end
    
    local content = table.concat(lines, "\n")
    pcall(function() writefile(PriorityFile, content) end)
end

local function AddPriorityWords(prefix, words)
    prefix = prefix:lower():gsub("[%s%c]+", "")
    if prefix == "" then return false, "No prefix provided" end
    
    if not PriorityWords[prefix] then
        PriorityWords[prefix] = {}
        table.insert(PriorityPrefixList, prefix)
        table.sort(PriorityPrefixList)
    end
    
    local addedWords = {}
    for part in words:gmatch("[^,]+") do
        local word = part:gsub("[%s%c]+", ""):lower()
        if #word >= 2 then
            if not PriorityWords[prefix][word] then
                PriorityWords[prefix][word] = true
                table.insert(addedWords, word)
            end
        end
    end
    
    if #addedWords > 0 then
        SavePriorityWords()
        return true, addedWords
    end
    return false, "No new words added"
end

local function RemovePriorityWords(prefix, words)
    prefix = prefix:lower():gsub("[%s%c]+", "")
    if prefix == "" or not PriorityWords[prefix] then 
        return false, "Prefix not found" 
    end
    
    local removedWords = {}
    for part in words:gmatch("[^,]+") do
        local word = part:gsub("[%s%c]+", ""):lower()
        if PriorityWords[prefix][word] then
            PriorityWords[prefix][word] = nil
            table.insert(removedWords, word)
        end
    end
    
    local hasWords = false
    for _ in pairs(PriorityWords[prefix]) do
        hasWords = true
        break
    end
    if not hasWords then
        PriorityWords[prefix] = nil
        for i, p in ipairs(PriorityPrefixList) do
            if p == prefix then
                table.remove(PriorityPrefixList, i)
                break
            end
        end
    end
    
    if #removedWords > 0 then
        SavePriorityWords()
        return true, removedWords
    end
    return false, "No words found to remove"
end

local function DeletePriorityPrefix(prefix)
    prefix = prefix:lower():gsub("[%s%c]+", "")
    if PriorityWords[prefix] then
        PriorityWords[prefix] = nil
        for i, p in ipairs(PriorityPrefixList) do
            if p == prefix then
                table.remove(PriorityPrefixList, i)
                break
            end
        end
        SavePriorityWords()
        return true
    end
    return false
end

local function GetPriorityWordsForPrefix(prefix)
    prefix = prefix:lower():gsub("[%s%c]+", "")
    if PriorityWords[prefix] then
        local words = {}
        for w in pairs(PriorityWords[prefix]) do
            table.insert(words, w)
        end
        table.sort(words, function(a, b) return #a < #b end)
        return words
    end
    return {}
end

local function LoadCustomWordsFromFile(filePath)
    local words = {}
    if isfile and isfile(filePath) then
        local success, content = pcall(function() return readfile(filePath) end)
        if success and content then
            for line in content:gmatch("[^\r\n]+") do
                local clean = line:gsub("[%s%c]+", ""):lower()
                if #clean > 0 then
                    words[clean] = true
                end
            end
        end
    end
    return words
end

local function SaveCustomWordsToFile(filePath, words)
    if not writefile then return end
    local lines = {}
    for word in pairs(words) do
        table.insert(lines, word)
    end
    table.sort(lines)
    local content = table.concat(lines, "\n")
    pcall(function() writefile(filePath, content) end)
end

local function FetchPrimaryWords()
    UpdateStatus("Fetching PRIMARY word list from web...", THEME.Warning)
    local success, res = pcall(function()
        return request({Url = givesUrl, Method = "GET"})
    end)
    
    local onlineWords = {}
    if success and res and res.Body then
        writefile(givesFileName, res.Body)
        UpdateStatus("Primary words fetched!", THEME.Success)
        
        for w in res.Body:gmatch("[^\r\n]+") do
            local clean = w:gsub("[%s%c]+", ""):lower()
            if #clean > 0 then
                onlineWords[clean] = true
            end
        end
    else
        if isfile and isfile(givesFileName) then
            local content = readfile(givesFileName)
            for w in content:gmatch("[^\r\n]+") do
                local clean = w:gsub("[%s%c]+", ""):lower()
                if #clean > 0 then
                    onlineWords[clean] = true
                end
            end
        end
    end
    
    local customWords = LoadCustomWordsFromFile(customGivesFile)
    
    local allPrimaryWords = {}
    for word in pairs(onlineWords) do
        table.insert(allPrimaryWords, word)
    end
    for word in pairs(customWords) do
        if not onlineWords[word] then
            table.insert(allPrimaryWords, word)
        end
    end
    table.sort(allPrimaryWords)
    
    local mergedContent = table.concat(allPrimaryWords, "\n")
    
    UpdateStatus("Primary: " .. #onlineWords .. " online + " .. (#allPrimaryWords - #onlineWords) .. " custom = " .. #allPrimaryWords, THEME.Success)
    return true, mergedContent
end

