local function GetMatchLength(str, prefix)
    local len = 0
    local max = math.min(#str, #prefix)
    for i = 1, max do
        local pb = string.byte(prefix, i)
        local sb = string.byte(str, i)
        if pb == 35 or pb == sb then
            len = i
        else
            break
        end
    end
    return len
end

local function AddToCustomTracking(word, fileType)
    if not writefile then return end
    
    local tracking = {}
    if isfile and isfile(CustomAddedFile) then
        local success, content = pcall(function() return readfile(CustomAddedFile) end)
        if success and content then
            for line in content:gmatch("[^\r\n]+") do
                local w, type = line:match("([^:]+):(.+)")
                if w and type then
                    tracking[w] = type
                end
            end
        end
    end
    
    if fileType == "both" then
        tracking[word] = "both"
    elseif fileType == "fallback" then
        if tracking[word] ~= "both" then
            tracking[word] = "fallback"
        end
    elseif fileType == "gives" then
        if tracking[word] ~= "both" then
            tracking[word] = "gives"
        end
    end
    
    local lines = {}
    for w, t in pairs(tracking) do
        table.insert(lines, w .. ":" .. t)
    end
    table.sort(lines)
    pcall(function() writefile(CustomAddedFile, table.concat(lines, "\n")) end)
end

local function RemoveFromCustomTracking(word)
    if not writefile or not isfile then return end
    if not isfile(CustomAddedFile) then return end
    
    local words = {}
    local success, content = pcall(function() return readfile(CustomAddedFile) end)
    if success and content then
        for line in content:gmatch("[^\r\n]+") do
            local w = line:gsub("[%s%c]+", ""):lower()
            if #w > 0 and w ~= word then
                table.insert(words, w)
            end
        end
    end
    
    local newContent = table.concat(words, "\n")
    pcall(function() writefile(CustomAddedFile, newContent) end)
end

local function AddWordsToCustomFile(filePath, words)
    if not writefile or not isfile then
        ShowToast("File writing not supported!", "error")
        return false
    end
    
    local customWords = LoadCustomWordsFromFile(filePath)
    
    local addedWords = {}
    for part in words:gmatch("[^,]+") do
        local word = part:gsub("[%s%c]+", ""):lower()
        if #word >= 2 then
            if not customWords[word] then
                customWords[word] = true
                table.insert(addedWords, word)
            end
        end
    end
    
    if #addedWords == 0 then
        ShowToast("No new words to add (all already exist)!", "warning")
        return false
    end
    
    SaveCustomWordsToFile(filePath, customWords)
    return true, addedWords
end

