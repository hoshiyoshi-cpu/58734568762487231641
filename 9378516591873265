end

local RefreshUsedWords
local lastRefreshHash = ""

RefreshUsedWords = function()
    if not UsedWordsFrame.Visible then return end
    
    local hash = ""
    for w, t in pairs(UsedWords) do
        hash = hash .. w .. tostring(t)
    end
    for w, _ in pairs(Blacklist) do
        hash = hash .. w .. "bl"
    end
    hash = hash .. (UWSearchBox.Text or "")
    
    if hash == lastRefreshHash then return end
    lastRefreshHash = hash
    
    for _, c in ipairs(UWList:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end
    
    local query = UWSearchBox.Text:lower():gsub("[%s%c]+", "")
    local usedList = {}
    local blacklistedList = {}
    
    for w, t in pairs(UsedWords) do 
        table.insert(usedList, {word = w, time = t}) 
    end
    table.sort(usedList, function(a, b) return a.time > b.time end)
    
    for w, _ in pairs(Blacklist) do 
        table.insert(blacklistedList, w) 
    end
    
    UWCountLabel.Text = #usedList .. " used, " .. #blacklistedList .. " blacklisted"
    
    local i = 0
    local scrollTarget = nil
    
    for _, entry in ipairs(usedList) do
        local w = entry.word
        i = i + 1
        local row = Instance.new("Frame", UWList)
        row.Size = UDim2.new(1, -6, 0, 22)
        row.BackgroundColor3 = (i % 2 == 0) and Color3.fromRGB(25, 25, 30) or Color3.fromRGB(30, 30, 35)
        row.BorderSizePixel = 0
        row.LayoutOrder = i
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)
        
        local lbl = Instance.new("TextLabel", row)
        lbl.Text = w
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 12
        lbl.TextColor3 = THEME.Success
        lbl.Size = UDim2.new(1, -10, 1, 0)
        lbl.Position = UDim2.new(0, 5, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        
        local del = Instance.new("TextButton", row)
        del.Text = "X"
        del.Font = Enum.Font.GothamBold
        del.TextSize = 11
        del.TextColor3 = Color3.fromRGB(255, 80, 80)
        del.Size = UDim2.new(0, 22, 1, 0)
        del.Position = UDim2.new(1, -22, 0, 0)
        del.BackgroundTransparency = 1
        del.MouseButton1Click:Connect(function()
            UsedWords[w] = nil
            ShowToast("Removed from used: " .. w, "warning")
            RefreshUsedWords()
            forceUpdateList = true
        end)
        
        if query ~= "" and w:find(query, 1, true) then
            row.BackgroundColor3 = Color3.fromRGB(40, 70, 40)
            if not scrollTarget then scrollTarget = i end
        end
    end
    
    if #blacklistedList > 0 then
        i = i + 1
        local row = Instance.new("Frame", UWList)
        row.Size = UDim2.new(1, -6, 0, 22)
        row.BackgroundColor3 = (i % 2 == 0) and Color3.fromRGB(25, 25, 30) or Color3.fromRGB(30, 30, 35)
        row.BorderSizePixel = 0
        row.LayoutOrder = i
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)
        
        local lbl = Instance.new("TextLabel", row)
        lbl.Text = #blacklistedList .. " blacklisted words (use Blacklist button to manage)"
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 11
        lbl.TextColor3 = Color3.fromRGB(255, 150, 150)
        lbl.Size = UDim2.new(1, -10, 1, 0)
        lbl.Position = UDim2.new(0, 5, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.TextXAlignment = Enum.TextXAlignment.Left
    end
    
    UWList.CanvasSize = UDim2.new(0, 0, 0, UWLayout.AbsoluteContentSize.Y)
    if scrollTarget then
        UWList.CanvasPosition = Vector2.new(0, math.max(0, (scrollTarget - 1) * 24 - 50))
    end
