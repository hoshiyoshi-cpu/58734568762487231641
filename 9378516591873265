local function FetchPrimaryWords()
    UpdateStatus("Fetching PRIMARY word list from web...", THEME.Warning)
    local success, res = pcall(function()
        return request({Url = givesUrl, Method = "GET"})
    end)
    
    local onlineWords = {}
    if success and res and res.Body then
        -- Save the original web version
        writefile(givesFileName, res.Body)
        UpdateStatus("Primary words fetched!", THEME.Success)
        
        for w in res.Body:gmatch("[^\r\n]+") do
            local clean = w:gsub("[%s%c]+", ""):lower()
            if #clean > 0 then
                onlineWords[clean] = true
            end
        end
    else
        -- If download fails, try to load existing file
        if isfile and isfile(givesFileName) then
            local content = readfile(givesFileName)
            for w in content:gmatch("[^\r\n]+") do
                local clean = w:gsub("[%s%c]+", ""):lower()
                if #clean > 0 then
                    onlineWords[clean] = true
                end
            end
        end
    end
    
    -- Load custom gives words from separate file
    local customWords = LoadCustomWordsFromFile(customGivesFile)
    
    -- Merge online + custom gives words (but don't save to web file)
    local allPrimaryWords = {}
    for word in pairs(onlineWords) do
        table.insert(allPrimaryWords, word)
    end
    for word in pairs(customWords) do
        if not onlineWords[word] then
            table.insert(allPrimaryWords, word)
        end
    end
    table.sort(allPrimaryWords)
    
    -- Return the merged list as content
    local mergedContent = table.concat(allPrimaryWords, "\n")
    
    UpdateStatus("Primary: " .. #onlineWords .. " online + " .. (#allPrimaryWords - #onlineWords) .. " custom = " .. #allPrimaryWords, THEME.Success)
    return true, mergedContent
end

local function FetchFallbackWords()
    UpdateStatus("Fetching FALLBACK word list from web...", THEME.Warning)
