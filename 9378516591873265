-- Reload all word lists
local function ReloadAllWordLists()
    -- Reload using fetch functions (web + custom)
    local primarySuccess, primaryContent = FetchPrimaryWords()
    LoadPrimaryWords(primaryContent)
    
    local fallbackSuccess, fallbackContent = FetchFallbackWords()
    LoadFallbackWords(fallbackContent)
    
    RefreshGiveWordsLookup()
    
    -- Rebuild buckets with ALL words
    Buckets = {}
    for _, w in ipairs(AllWords) do
        local c = w:sub(1,1) or ""
        if c == "" then c = "#" end
        Buckets[c] = Buckets[c] or {}
        local exists = false
        for _, existing in ipairs(Buckets[c]) do
            if existing == w then exists = true; break end
        end
        if not exists then
            table.insert(Buckets[c], w)
        end
    end
    
    forceUpdateList = true
end

-- FullRefresh function
local function FullRefresh()
    ShowToast("Refreshing word lists...", "warning")
    
    AllWords = {}
    PrimaryWords = {}
    FallbackWords = {}
    SeenWords = {}
    
    local primarySuccess, primaryContent = FetchPrimaryWords()
    LoadPrimaryWords(primaryContent)
    
    local fallbackSuccess, fallbackContent = FetchFallbackWords()
    LoadFallbackWords(fallbackContent)
    
    RefreshGiveWordsLookup()
    
    Buckets = {}
    for _, w in ipairs(AllWords) do
        local c = w:sub(1,1) or ""
        if c == "" then c = "#" end
        Buckets[c] = Buckets[c] or {}
        table.insert(Buckets[c], w)
    end
    
    PrimaryBuckets = {}
    for _, w in ipairs(PrimaryWords) do
        local c = w:sub(1,1) or ""
        if c == "" then c = "#" end
        PrimaryBuckets[c] = PrimaryBuckets[c] or {}
        table.insert(PrimaryBuckets[c], w)
    end
    
    FallbackBuckets = {}
    for _, w in ipairs(FallbackWords) do
        local c = w:sub(1,1) or ""
        if c == "" then c = "#" end
        FallbackBuckets[c] = FallbackBuckets[c] or {}
        table.insert(FallbackBuckets[c], w)
    end
    
    SeenWords = nil
    
    forceUpdateList = true
    lastDetected = "---"
    UpdateList(lastDetected, lastRequiredLetter)
    
    StatusText.Text = "Refreshed! " .. #AllWords .. " total words (" .. #PrimaryWords .. " gives, " .. #FallbackWords .. " fallback)"
    StatusText.TextColor3 = THEME.Success
    Tween(StatusDot, {BackgroundColor3 = THEME.Success})
    
    ShowToast("Refreshed! " .. #PrimaryWords .. " gives, " .. #FallbackWords .. " fallback", "success")
end

