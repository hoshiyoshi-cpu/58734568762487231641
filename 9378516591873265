local function LoadCustomWordsFromFile(filePath)
    local words = {}
    if isfile and isfile(filePath) then
        local success, content = pcall(function() return readfile(filePath) end)
        if success and content then
            for line in content:gmatch("[^\r\n]+") do
                local clean = line:gsub("[%s%c]+", ""):lower()
                if #clean > 0 then
                    words[clean] = true
                end
            end
        end
    end
    return words
end

local function SaveCustomWordsToFile(filePath, words)
    if not writefile then return end
    local lines = {}
    for word in pairs(words) do
        table.insert(lines, word)
    end
    table.sort(lines)
    local content = table.concat(lines, "\n")
    pcall(function() writefile(filePath, content) end)
end

