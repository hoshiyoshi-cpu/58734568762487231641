local usedWordsChanged = false
local function ScheduleUsedWordsRefresh()
    if UsedWordsFrame.Visible and not usedWordsChanged then
        usedWordsChanged = true
        task.defer(function()
            task.wait(0.1)
            if UsedWordsFrame.Visible then
                RefreshUsedWords()
            end
            usedWordsChanged = false
        end)
    end
end

local originalUsedWords = UsedWords
UsedWords = setmetatable({}, {
    __index = originalUsedWords,
    __newindex = function(t, k, v)
        originalUsedWords[k] = v
        ScheduleUsedWordsRefresh()
        forceUpdateList = true
    end,
    __pairs = function(t)
        return pairs(originalUsedWords)
    end
})

