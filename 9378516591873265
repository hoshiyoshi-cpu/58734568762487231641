    WBSearchBtn.BackgroundColor3 = THEME.Accent
    WBSearchBtn.Size = UDim2.new(0.1, 0, 0, 24)
    WBSearchBtn.Position = UDim2.new(0.88, 0, 0, 45)
    Instance.new("UICorner", WBSearchBtn).CornerRadius = UDim.new(0, 4)

    local WBList = Instance.new("ScrollingFrame", WordBrowserFrame)
    WBList.Size = UDim2.new(1, -20, 1, -125)
    WBList.Position = UDim2.new(0, 10, 0, 115)
    WBList.BackgroundTransparency = 1
    WBList.ScrollBarThickness = 3
    WBList.ScrollBarImageColor3 = THEME.Accent
    WBList.CanvasSize = UDim2.new(0,0,0,0)

    local WBLayout = Instance.new("UIListLayout", WBList)
    WBLayout.Padding = UDim.new(0, 2)
    WBLayout.SortOrder = Enum.SortOrder.LayoutOrder

    local function SearchWords()
        for _, c in ipairs(WBList:GetChildren()) do
            if c:IsA("GuiObject") and c.Name ~= "UIListLayout" then c:Destroy() end
        end

        local eVal = WBEndBox.Text
        local lVal = tonumber(WBLengthBox.Text)
        if eVal == "Ends with..." then eVal = "" end
        eVal = eVal:lower():gsub("[%s%c]+", "")

        -- Parse comma-separated suffixes and maintain order (priority)
        local newSuffixModes = {}
        for part in eVal:gmatch("[^,]+") do
            local clean = part:gsub("[%s%c]+", "")
            if #clean > 0 then 
                table.insert(newSuffixModes, clean)
            end
        end
        
        Config.SuffixModes = newSuffixModes
        Config.SuffixMode = eVal
        Config.LengthMode = lVal or 0
        SaveConfig()
        
        -- Build priority map (lower index = higher priority)
        local suffixPriority = {}
        for idx, s in ipairs(Config.SuffixModes) do
            suffixPriority[s] = idx
        end

        local priorityResults = {}  -- priority level -> list of words
        local MAX_RESULTS = 200
        local seenWords = {}  -- Track seen words across all priorities
        
        local function getWordPriority(w)
            local bestPriority = 999
            for _, s in ipairs(Config.SuffixModes) do
                if #w >= #s and w:sub(-#s) == s then
                    local p = suffixPriority[s] or 999
                    if p < bestPriority then
                        bestPriority = p
                    end
                end
            end
            return bestPriority
        end
        
        local function matchesLength(w)
            return (lVal == nil or lVal == 0) or (#w == lVal)
        end
        
        -- If no suffixes, just show all words alphabetically
        if #Config.SuffixModes == 0 then
            local allWords = {}
            for _, w in ipairs(PrimaryWords) do
                if not Blacklist[w] and not UsedWords[w] and matchesLength(w) then
                    if not seenWords[w] then
                        seenWords[w] = true
                        table.insert(allWords, w)
                    end
                end
            end
            for _, w in ipairs(FallbackWords) do
                if not Blacklist[w] and not UsedWords[w] and matchesLength(w) then
                    if not seenWords[w] then
                        seenWords[w] = true
                        table.insert(allWords, w)
                    end
                end
            end
            table.sort(allWords)
            
            local displayLimit = math.min(200, #allWords)
            for i = 1, displayLimit do
                local w = allWords[i]
                local row = Instance.new("TextButton", WBList)
                row.Size = UDim2.new(1, -6, 0, 22)
                row.BackgroundColor3 = (i % 2 == 0) and Color3.fromRGB(25,25,30) or Color3.fromRGB(30,30,35)
                row.Text = ""
                row.AutoButtonColor = false
                Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)
                row.MouseButton1Click:Connect(function()
                    Tween(row, {BackgroundColor3 = THEME.Accent}, 0.2)
                    task.delay(0.2, function()
                        Tween(row, {BackgroundColor3 = (i % 2 == 0) and Color3.fromRGB(25,25,30) or Color3.fromRGB(30,30,35)}, 0.2)
                    end)
                    if SearchBox then
                        SearchBox.Text = w
                    end
                end)
                local lbl = Instance.new("TextLabel", row)
                local isPrimary = false
                for _, pw in ipairs(PrimaryWords) do
                    if pw == w then 
                        isPrimary = true 
                        break 
                    end
                end
                lbl.Text = w
                lbl.Font = Enum.Font.Gotham
                lbl.TextSize = 12
                lbl.TextColor3 = isPrimary and THEME.Success or THEME.Text
                lbl.Size = UDim2.new(1, -10, 1, 0)
                lbl.Position = UDim2.new(0, 5, 0, 0)
                lbl.BackgroundTransparency = 1
                lbl.TextXAlignment = Enum.TextXAlignment.Left
            end
            
            WBList.CanvasSize = UDim2.new(0,0,0, WBLayout.AbsoluteContentSize.Y)
            lastDetected = "---"
            forceUpdateList = true
            if UpdateList then UpdateList(lastDetected, lastRequiredLetter) end
            return
        end
        
        -- WITH SUFFIXES: Collect ALL words from BOTH sources
        local allCandidates = {}
        
        -- Add Primary words
        for _, w in ipairs(PrimaryWords) do
            if not Blacklist[w] and not UsedWords[w] and matchesLength(w) then
                local priority = getWordPriority(w)
                if priority < 999 then
                    if not seenWords[w] then
                        seenWords[w] = true
                        table.insert(allCandidates, {word = w, priority = priority})
                    end
                end
            end
        end
        
        -- Add Fallback words
        for _, w in ipairs(FallbackWords) do
            if not Blacklist[w] and not UsedWords[w] and matchesLength(w) then
                local priority = getWordPriority(w)
                if priority < 999 then
                    if not seenWords[w] then
                        seenWords[w] = true
                        table.insert(allCandidates, {word = w, priority = priority})
                    end
                end
            end
        end
        
        -- Group by priority
        for _, candidate in ipairs(allCandidates) do
            local p = candidate.priority
            if not priorityResults[p] then
                priorityResults[p] = {}
            end
            table.insert(priorityResults[p], candidate.word)
        end
        
        -- Sort results by priority FIRST, then by length within each priority
        local sortedResults = {}
        local priorities = {}
        for p, _ in pairs(priorityResults) do
            table.insert(priorities, p)
        end
        table.sort(priorities)  -- Sort priorities (lower number = higher priority)
        
        for _, p in ipairs(priorities) do
            local group = priorityResults[p]
            -- Sort each priority group by length (shortest first), then alphabetically
            table.sort(group, function(a, b) 
                if #a ~= #b then 
                    return #a < #b 
                end
                return a < b
            end)
            for _, word in ipairs(group) do
                table.insert(sortedResults, word)
                if #sortedResults >= MAX_RESULTS then break end
            end
            if #sortedResults >= MAX_RESULTS then break end
        end
        
        -- Display results
        local displayLimit = math.min(200, #sortedResults)
        if displayLimit == 0 then
            ShowToast("No words found ending with: " .. eVal, "warning")
        end
        
        for i = 1, displayLimit do
            local w = sortedResults[i]
            local row = Instance.new("TextButton", WBList)
            row.Size = UDim2.new(1, -6, 0, 22)
