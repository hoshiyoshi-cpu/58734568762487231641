-- Strategic Sort - Give words first, then suffix matches, then others
local function StrategicSort(giveWords, fallbackWords, currentPrefix, usedWordsSet)
    local MAX_WORDS = 40
    
    local suffixList = Config.SuffixModes or {}
    local suffixPriority = {}
    for idx, s in ipairs(suffixList) do
        suffixPriority[s] = idx
    end
    
    -- Group fallback words by suffix match
    local suffixGroups = {}
    local noSuffixWords = {}
    
    for _, word in ipairs(fallbackWords) do
        local wl = word:lower()
        local matchedSuffix = nil
        local matchedPriority = 999
        
        for _, s in ipairs(suffixList) do
            if #wl >= #s and wl:sub(-#s) == s then
                local p = suffixPriority[s] or 999
                if p < matchedPriority then
                    matchedPriority = p
                    matchedSuffix = s
                end
            end
        end
        
        if matchedSuffix then
            if not suffixGroups[matchedPriority] then
                suffixGroups[matchedPriority] = {}
            end
            table.insert(suffixGroups[matchedPriority], word)
        else
            table.insert(noSuffixWords, word)
        end
    end
    
    -- Function to shuffle a table
    local function shuffle(t)
        for i = #t, 2, -1 do
            local j = math.random(i)
            t[i], t[j] = t[j], t[i]
        end
        return t
    end
    
    -- Shuffle suffix groups and no suffix words
    local shuffledNoSuffixWords = shuffle(noSuffixWords)
    
    local suffixGroupsProcessed = {}
    local sortedPriorities = {}
    for priority, _ in pairs(suffixGroups) do
        table.insert(sortedPriorities, priority)
    end
    table.sort(sortedPriorities)
    
    for _, priority in ipairs(sortedPriorities) do
        suffixGroupsProcessed[priority] = shuffle(suffixGroups[priority])
    end
    
    -- Build result: GIVE WORDS FIRST, then suffix matches, then others
    local result = {}
    
    -- 1. Give words (PRIMARY) - ALWAYS FIRST
    local shuffledGiveWords = shuffle(giveWords)
    for _, word in ipairs(shuffledGiveWords) do
        if #result >= MAX_WORDS then break end
        result[#result + 1] = word
    end
    
    -- 2. Suffix groups in priority order
    for _, priority in ipairs(sortedPriorities) do
        local group = suffixGroupsProcessed[priority]
        for _, word in ipairs(group) do
            if #result >= MAX_WORDS then break end
            result[#result + 1] = word
        end
        if #result >= MAX_WORDS then break end
    end
    
    -- 3. No-suffix words (lowest priority)
    for _, word in ipairs(shuffledNoSuffixWords) do
        if #result >= MAX_WORDS then break end
        result[#result + 1] = word
    end
    
    return result
end

-- Smart Sort - Give words first (medium gives prioritized, then short, then long), then fallback
local function SmartSort(giveWords, fallbackWords, currentPrefix, usedWordsSet)
    -- Separate GIVE words by length
    local mediumGiveWords = {}  -- 6-9 letter gives words (TOP PRIORITY)
    local shortGiveWords = {}    -- 1-5 letter gives words
    local longGiveWords = {}     -- 10+ letter gives words
    
    for _, word in ipairs(giveWords) do
        local len = #word
        if len >= 6 and len <= 9 then
            table.insert(mediumGiveWords, word)
        elseif len <= 5 then
            table.insert(shortGiveWords, word)
        else
            table.insert(longGiveWords, word)
        end
    end
    
    -- Shuffle each group randomly
    local function shuffle(t)
        for i = #t, 2, -1 do
            local j = math.random(i)
            t[i], t[j] = t[j], t[i]
        end
        return t
    end
    
    shuffle(mediumGiveWords)
    shuffle(shortGiveWords)
    shuffle(longGiveWords)
    
    -- Shuffle fallback words (they go after all gives)
    local shuffledFallback = shuffle(fallbackWords)
    
    -- Build result: GIVE WORDS FIRST (medium then short then long), then fallback
    local result = {}
    
    -- 1. Medium PRIMARY gives (6-9 letters) - HIGHEST PRIORITY
    for _, word in ipairs(mediumGiveWords) do
        if #result >= 40 then break end
        table.insert(result, word)
    end
    
    -- 2. Short PRIMARY gives (1-5 letters)
    for _, word in ipairs(shortGiveWords) do
        if #result >= 40 then break end
        table.insert(result, word)
    end
    
    -- 3. Long PRIMARY gives (10+ letters)
    for _, word in ipairs(longGiveWords) do
        if #result >= 40 then break end
        table.insert(result, word)
    end
    
    -- 4. Fallback words (after all gives)
    for _, word in ipairs(shuffledFallback) do
        if #result >= 40 then break end
        table.insert(result, word)
    end
    
    return result
end

