local function GetMatchLength(str, prefix)
    local len = 0
    local max = math.min(#str, #prefix)
    for i = 1, max do
        local pb = string.byte(prefix, i)
        local sb = string.byte(str, i)
        if pb == 35 or pb == sb then
            len = i
        else
            break
        end
    end
    return len
end

-- =============================================
-- MAIN WINDOW UPDATE LIST - GIVE WORDS ALWAYS FIRST
-- =============================================

local lastRequiredLetter = ""

UpdateList = function(detectedText, requiredLetter)
    local hash = (detectedText or "") .. "|" .. (requiredLetter or "") .. "|" .. (SearchBox.Text or "") .. "|" .. suffixMode .. "|" .. tostring(lengthMode) .. "|" .. sortMode
    if hash == lastUpdateHash and not forceUpdateList then return end
    lastUpdateHash = hash

    local searchPrefix = detectedText
    local isBacktracked = false
    local manualSearch = false

    if SearchBox and SearchBox.Text ~= "" then
        searchPrefix = SearchBox.Text:lower():gsub("[%s%c]+", "")
        manualSearch = true
        if requiredLetter and searchPrefix:sub(1,1) ~= requiredLetter:sub(1,1):lower() then
            requiredLetter = nil
        end
    end

    if not manualSearch and requiredLetter and #requiredLetter > 0 then
        local reqLen = GetMatchLength(requiredLetter, searchPrefix)
        if reqLen == #searchPrefix and #requiredLetter > #searchPrefix then
            searchPrefix = requiredLetter
        end
    end

    local firstChar = searchPrefix:sub(1,1)
    if firstChar == "#" then firstChar = nil end
    if (not firstChar or firstChar == "") and requiredLetter then
        firstChar = requiredLetter:sub(1,1):lower()
    end

    local prefixLen = #searchPrefix
    
    -- COLLECT GIVE WORDS (PRIMARY - from gives.txt) FIRST
    local giveWords = {}
    local giveBucket = firstChar and PrimaryBuckets[firstChar] or PrimaryWords
    if giveBucket then
        for _, w in ipairs(giveBucket) do
            if #giveWords >= 200 then break end
            if prefixLen == 0 or w:sub(1, prefixLen) == searchPrefix then
                if lengthMode == 0 or #w == lengthMode then
                    if not Blacklist[w] and not UsedWords[w] then
                        table.insert(giveWords, w)
                    end
                end
            end
        end
    end
    
    -- COLLECT FALLBACK WORDS (from lastletter.txt) - ONLY AFTER GIVE WORDS
    local fallbackWords = {}
    local fallbackBucket = firstChar and FallbackBuckets[firstChar] or FallbackWords
    if fallbackBucket then
        for _, w in ipairs(fallbackBucket) do
            if #fallbackWords >= 300 then break end
            if prefixLen == 0 or w:sub(1, prefixLen) == searchPrefix then
                if lengthMode == 0 or #w == lengthMode then
                    if not Blacklist[w] and not UsedWords[w] then
                        table.insert(fallbackWords, w)
                    end
                end
            end
        end
    end
    
    -- If no matches in either, try partial matching with GIVE words first
    if #giveWords == 0 and #fallbackWords == 0 then
        local maxPartialLen = 0
        local partialGiveMatches = {}
        local partialFallbackMatches = {}
        
        -- Check GIVE words first for partial matches
        if giveBucket then
            for _, w in ipairs(giveBucket) do
                if not Blacklist[w] and not UsedWords[w] then
                    if lengthMode == 0 or #w == lengthMode then
                        local mLen = GetMatchLength(w, searchPrefix)
                        if mLen > maxPartialLen then
                            maxPartialLen = mLen
                            partialGiveMatches = {w}
                            partialFallbackMatches = {}
                        elseif mLen == maxPartialLen and mLen > 0 then
                            table.insert(partialGiveMatches, w)
                        end
                    end
                end
            end
        end
        
        -- Then check FALLBACK words if needed
        if #partialGiveMatches == 0 and fallbackBucket then
            for _, w in ipairs(fallbackBucket) do
                if not Blacklist[w] and not UsedWords[w] then
                    if lengthMode == 0 or #w == lengthMode then
                        local mLen = GetMatchLength(w, searchPrefix)
                        if mLen > maxPartialLen then
                            maxPartialLen = mLen
                            partialFallbackMatches = {w}
                        elseif mLen == maxPartialLen and mLen > 0 then
                            table.insert(partialFallbackMatches, w)
                        end
                    end
                end
            end
        end
        
        if #partialGiveMatches > 0 or #partialFallbackMatches > 0 then
            giveWords = partialGiveMatches
            fallbackWords = partialFallbackMatches
            searchPrefix = searchPrefix:sub(1, maxPartialLen)
            isBacktracked = true
        end
    end
    
    -- Apply sorting based on selected mode
    local matches = {}
    
    if sortMode == "Strategic" then
        matches = StrategicSort(giveWords, fallbackWords, searchPrefix, UsedWords)
    elseif sortMode == "Smart" then
        matches = SmartSort(giveWords, fallbackWords, searchPrefix, UsedWords)
    elseif sortMode == "Random" then
        -- Random: shuffle gives, then shuffles fallback (gives still first)
        local function shuffle(t)
            for i = #t, 2, -1 do
                local j = math.random(i)
                t[i], t[j] = t[j], t[i]
            end
            return t
        end
        local shuffledGives = shuffle(giveWords)
        local shuffledFallback = shuffle(fallbackWords)
        for _, w in ipairs(shuffledGives) do table.insert(matches, w) end
        for _, w in ipairs(shuffledFallback) do table.insert(matches, w) end
    elseif sortMode == "Shortest" then
        -- Shortest: sort gives by length, then fallback by length (gives still first)
        table.sort(giveWords, function(a, b) 
            if #a ~= #b then return #a < #b end
            return a < b
        end)
        table.sort(fallbackWords, function(a, b) 
            if #a ~= #b then return #a < #b end
            return a < b
        end)
        for _, w in ipairs(giveWords) do table.insert(matches, w) end
        for _, w in ipairs(fallbackWords) do table.insert(matches, w) end
    else
        -- Default: gives first, then fallback
        for _, w in ipairs(giveWords) do table.insert(matches, w) end
        for _, w in ipairs(fallbackWords) do table.insert(matches, w) end
    end
    
    -- Limit to 40 words
    local limitedMatches = {}
    for i = 1, math.min(40, #matches) do
        table.insert(limitedMatches, matches[i])
    end
    matches = limitedMatches

    -- Display the results (limit to 15 visible buttons)
    local displayList = {}
    for i = 1, math.min(15, #matches) do
        table.insert(displayList, matches[i])
    end

    if #matches > 0 and not isBacktracked then
        currentBestMatch = matches[1]
    else
        currentBestMatch = nil
    end

    if isBacktracked then
        local accentRGB = ColorToRGB(THEME.Accent)
        StatusText.Text = "No match: <font color=\"rgb(" .. accentRGB .. ")\">" .. searchPrefix .. "</font>"
        StatusText.TextColor3 = THEME.SubText
    end

    -- Update buttons
    local giveWordsLookupLocal = GiveWordsLookup
    
    for i = 1, math.max(#displayList, #ButtonCache) do
        local w = displayList[i]
        local btn = ButtonCache[i]

        if w then
            local lbl
            if not btn then
                btn = Instance.new("TextButton")
                btn.Size = UDim2.new(1, -6, 0, 30)
                btn.BackgroundColor3 = THEME.ItemBG
                btn.Text = ""
                btn.AutoButtonColor = false
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

                lbl = Instance.new("TextLabel", btn)
                lbl.Name = "Label"
                lbl.Size = UDim2.new(1, -20, 1, 0)
                lbl.Position = UDim2.new(0, 10, 0, 0)
                lbl.BackgroundTransparency = 1
                lbl.Font = Enum.Font.GothamMedium
                lbl.TextSize = 14
                lbl.TextXAlignment = Enum.TextXAlignment.Left
                lbl.RichText = true

                -- Add give indicator for PRIMARY words
                if giveWordsLookupLocal and giveWordsLookupLocal[w] then
                    local giveIndicator = Instance.new("TextLabel", btn)
                    giveIndicator.Name = "GiveIndicator"
                    giveIndicator.Size = UDim2.new(0, 30, 1, 0)
                    giveIndicator.Position = UDim2.new(1, -35, 0, 0)
                    giveIndicator.BackgroundTransparency = 1
                    giveIndicator.Text = "🎁"
                    giveIndicator.Font = Enum.Font.GothamBold
                    giveIndicator.TextSize = 12
                    giveIndicator.TextColor3 = THEME.Success
                    giveIndicator.TextXAlignment = Enum.TextXAlignment.Right
                    lbl.Size = UDim2.new(1, -45, 1, 0)
                end

                btn.MouseEnter:Connect(function() Tween(btn, {BackgroundColor3 = Color3.fromRGB(45,45,55)}) end)
                btn.MouseLeave:Connect(function() Tween(btn, {BackgroundColor3 = THEME.ItemBG}) end)

                btn.MouseButton1Click:Connect(function()
                    local d = ButtonData[btn]
                    if d then
                        local l = btn:FindFirstChild("Label")
                        if l then l.TextColor3 = THEME.Success end
                        Tween(btn, {BackgroundColor3 = Color3.fromRGB(30,60,40)})
                        UsedWords[d.word] = tick()
                        forceUpdateList = true
                    end
                end)

                btn.Parent = ScrollList
                table.insert(ButtonCache, btn)
            else
                lbl = btn:FindFirstChild("Label")
                btn.Visible = true
                btn.Parent = ScrollList
                btn.BackgroundColor3 = THEME.ItemBG
                if lbl then lbl.TextColor3 = THEME.Text end
                
                local existingIndicator = btn:FindFirstChild("GiveIndicator")
                if giveWordsLookupLocal and giveWordsLookupLocal[w] then
                    if not existingIndicator then
                        local giveIndicator = Instance.new("TextLabel", btn)
                        giveIndicator.Name = "GiveIndicator"
                        giveIndicator.Size = UDim2.new(0, 30, 1, 0)
                        giveIndicator.Position = UDim2.new(1, -35, 0, 0)
                        giveIndicator.BackgroundTransparency = 1
                        giveIndicator.Text = "🎁"
                        giveIndicator.Font = Enum.Font.GothamBold
                        giveIndicator.TextSize = 12
                        giveIndicator.TextColor3 = THEME.Success
                        giveIndicator.TextXAlignment = Enum.TextXAlignment.Right
                        if lbl then lbl.Size = UDim2.new(1, -45, 1, 0) end
                    end
                elseif existingIndicator then
                    existingIndicator:Destroy()
                    if lbl then lbl.Size = UDim2.new(1, -20, 1, 0) end
                end
            end

            ButtonData[btn] = {word = w, detected = detectedText}

            local accentRGB = ColorToRGB(THEME.Accent)
            if sortMode == "Strategic" then
                if i == 1 then 
                    accentRGB = "100,255,140"
                elseif i == 2 then 
                    accentRGB = "255,200,100"
                elseif i == 3 then 
                    accentRGB = "100,200,255"
                end
            elseif i == 1 then
                accentRGB = "100,255,140"
            elseif i == 2 then
                accentRGB = "255,180,200"
            elseif i == 3 then
                accentRGB = "100,200,255"
            end

            local textRGB = ColorToRGB(THEME.Text)
            local displayText = ""
            if isBacktracked then
                local prefix = w:sub(1, #searchPrefix)
                local suffix = w:sub(#searchPrefix + 1)
                displayText = "<font color=\"rgb(" .. accentRGB .. ")\">" .. prefix .. "</font>"
                    .. "<font color=\"rgb(" .. textRGB .. ")\">" .. suffix .. "</font>"
            else
                local prefix = w:sub(1, #(detectedText or ""))
                local suffix = w:sub(#(detectedText or "") + 1)
                displayText = "<font color=\"rgb(" .. accentRGB .. ")\">" .. prefix .. "</font>"
                    .. "<font color=\"rgb(" .. textRGB .. ")\">" .. suffix .. "</font>"
            end

            if lbl then lbl.Text = displayText end
        else
            if btn then
                btn.Visible = false
                ButtonData[btn] = nil
            end
        end
    end

    ScrollList.CanvasSize = UDim2.new(0,0,0, UIListLayout.AbsoluteContentSize.Y)
end

